# Docker image to use for simulations
DOCKER_IMAGE=nntehranchi/osr-bean-p:latest

# Run:ai cluster settings
RUNAI_PROJECT=busch-lab
RUNAI_NAMESPACE=runai-busch-lab

# Resource limits per job
CPU_COUNT=2
MEMORY_LIMIT=4Gi
GPU_COUNT=0

# PVC (persistent volume claim) for input/output data
PVC_NAME=opensimroot-data
PVC_MOUNT=/sim

# GitHub token for pushing results (required for run-all-sims.sh)
# GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# GitHub repo to push results to
GITHUB_REPO=n-tehranchi/osr-bean-p

# Set to "true" to print commands without submitting
DRY_RUN=false
